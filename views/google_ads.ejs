<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="Cache-Control" content="no-cache">
    <meta http-equiv="pragma" content="no-cache">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google Ads</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/google_ads.css">
</head>

<body class="ga-body">
    <div id="google-ads-app" :class="{ 'ga-nav-collapsed': isNavCollapsed }" v-cloak>
        <header class="ga-topbar">
            <div class="ga-topbar-left">
                <button class="ga-icon-button" type="button" aria-label="Toggle navigation" @click="toggleNavigation">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                <a class="ga-brand" href="/aw/campaigns" aria-label="Google Ads campaigns">
                    <svg class="ga-ads-logo" enable-background="new 0 0 192 192" viewBox="0 0 192 192"
                        xmlns="http://www.w3.org/2000/svg">
                        <g>
                            <rect fill="none" height="192" width="192"></rect>
                            <g>
                                <rect fill="#FBBC04" height="58.67"
                                    transform="matrix(0.5 -0.866 0.866 0.5 -46.2127 103.666)" width="117.33" x="8"
                                    y="62.52"></rect>
                                <path
                                    d="M180.07,127.99L121.4,26.38c-8.1-14.03-26.04-18.84-40.07-10.74c-14.03,8.1-18.84,26.04-10.74,40.07 l58.67,101.61c8.1,14.03,26.04,18.83,40.07,10.74C183.36,159.96,188.16,142.02,180.07,127.99z"
                                    fill="#4285F4"></path>
                                <circle cx="37.34" cy="142.66" fill="#34A853" r="29.33"></circle>
                            </g>
                        </g>
                    </svg>
                    <svg class="lockup-google-logo" height="24" viewBox="0 0 74 24" width="74" xmlns="http://www.w3.org/2000/svg"><path d="M9.24 8.19v2.46h5.88c-.18 1.38-.64 2.39-1.34 3.1-.86.86-2.2 1.8-4.54 1.8-3.62 0-6.45-2.92-6.45-6.54s2.83-6.54 6.45-6.54c1.95 0 3.38.77 4.43 1.76L15.4 2.5C13.94 1.08 11.98 0 9.24 0 4.28 0 .11 4.04.11 9s4.17 9 9.13 9c2.68 0 4.7-.88 6.28-2.52 1.62-1.62 2.13-3.91 2.13-5.75 0-.57-.04-1.1-.13-1.54H9.24zm15.76-2c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52zm28.58-8.03h-.09c-.57-.68-1.67-1.3-3.06-1.3C47.53 6.19 45 8.72 45 12c0 3.26 2.53 5.81 5.43 5.81 1.39 0 2.49-.62 3.06-1.32h.09v.81c0 2.22-1.19 3.41-3.1 3.41-1.56 0-2.53-1.12-2.93-2.07l-2.22.92c.64 1.54 2.33 3.43 5.15 3.43 2.99 0 5.52-1.76 5.52-6.05V6.49h-2.42v1zm-2.93 8.03c-1.76 0-3.1-1.5-3.1-3.52 0-2.05 1.34-3.52 3.1-3.52 1.74 0 3.1 1.5 3.1 3.54.01 2.03-1.36 3.5-3.1 3.5zM38 6.19c-3.21 0-5.83 2.44-5.83 5.81 0 3.34 2.62 5.81 5.83 5.81s5.83-2.46 5.83-5.81c0-3.37-2.62-5.81-5.83-5.81zm0 9.33c-1.76 0-3.28-1.45-3.28-3.52 0-2.09 1.52-3.52 3.28-3.52s3.28 1.43 3.28 3.52c0 2.07-1.52 3.52-3.28 3.52zM58 .24h2.51v17.57H58zm10.26 15.28c-1.3 0-2.22-.59-2.82-1.76l7.77-3.21-.26-.66c-.48-1.3-1.96-3.7-4.97-3.7-2.99 0-5.48 2.35-5.48 5.81 0 3.26 2.46 5.81 5.76 5.81 2.66 0 4.2-1.63 4.84-2.57l-1.98-1.32c-.66.96-1.56 1.6-2.86 1.6zm-.18-7.15c1.03 0 1.91.53 2.2 1.28l-5.25 2.17c0-2.44 1.73-3.45 3.05-3.45z"></path></svg>
                    <span>Ads</span>
                </a>
                <button class="ga-account-button" type="button">
                    <span>{{ account.id }}</span>
                    <small>{{ account.phone }}</small>
                    <span class="material-symbols-outlined">arrow_drop_down</span>
                </button>
                <!-- <label class="ga-search">
                    <span class="material-symbols-outlined">search</span>
                    <input type="text" placeholder="Search for a page or campaign">
                </label> -->
            </div>
            <div class="ga-topbar-actions">
                <button class="ga-tool-button" type="button">
                    <span class="material-symbols-outlined">search</span>
                    <span>Search</span>
                </button>
                <button class="ga-tool-button" type="button" data-tooltip="Appearance">
                    <span class="material-symbols-outlined">responsive_layout</span>
                    <span>Appearance</span>
                </button>
                <button class="ga-tool-button" type="button" @click="reloadData" data-tooltip="Refresh">
                    <span class="material-symbols-outlined">refresh</span>
                    <span>Refresh</span>
                </button>
                <button class="ga-tool-button" type="button" data-tooltip="Open the quick help panel">
                    <span class="material-symbols-outlined">help</span>
                    <span>Help</span>
                </button>
                <button class="ga-tool-button ga-notifications" type="button">
                    <span class="material-symbols-outlined">notifications</span>
                    <span>Notifications</span>
                    <b>!</b>
                </button>
                <div class="ga-profile">
                    <span>{{ account.phone }} {{ account.id }}</span>
                    <small>{{ account.name }}</small>
                </div>
                <div class="ga-avatar">伟全</div>
            </div>
        </header>

        <div class="ga-shell">
            <aside class="ga-rail" aria-label="Main navigation">
                <div class="ga-create-block">
                    <button class="ga-create-button" type="button" aria-label="Create">
                        <span class="ga-create-tooltip">Create</span>
                    </button>
                    <span class="ga-create-text">Create</span>
                </div>
                <!-- <a class="ga-rail-item" href="/aw/campaigns">
                    <span class="material-symbols-outlined">overview</span>
                    <span>Overview</span>
                </a> -->
                <a class="ga-rail-item" href="/aw/campaigns">
                    <span class="material-symbols-outlined">contacts</span>
                    <span>Accounts</span>
                </a>
                <a class="ga-rail-item active" href="/aw/campaigns">
                    <span class="material-symbols-outlined">campaign</span>
                    <span>Campaigns</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">rewarded_ads</span>
                    <span>Goals</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">construction</span>
                    <span>Tools</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">payment</span>
                    <span>Billing</span>
                </a>
                <a class="ga-rail-item" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span>Admin</span>
                </a>
            </aside>

            <nav class="ga-sidebar" aria-label="Campaign navigation">
                <a class="ga-sidebar-link" href="#">Overview</a>
                <a class="ga-sidebar-link" href="#">Recommendations</a>
                <div class="ga-sidebar-group">
                    <button class="ga-sidebar-group-title" type="button">
                        <span>Insights and reports</span>
                        <span class="material-symbols-outlined">expand_more</span>
                    </button>
                    <a class="ga-sidebar-link" href="/aw/reporteditor/view">Report editor</a>
                    <a class="ga-sidebar-link" href="#">Dashboards</a>
                </div>
                <div class="ga-sidebar-group open">
                    <button class="ga-sidebar-group-title" type="button">
                        <span>Campaigns</span>
                        <span class="material-symbols-outlined">expand_less</span>
                    </button>
                    <a class="ga-sidebar-link" :class="{ active: pageMode === 'campaigns' }" href="/aw/campaigns">Campaigns</a>
                    <a class="ga-sidebar-link" :class="{ active: pageMode === 'adgroups' }" :href="adGroupsHref">Ad groups</a>
                    <a class="ga-sidebar-link" :class="{ active: pageMode === 'adassets' }" :href="adAssetsHref">Ad assets</a>
                    <a class="ga-sidebar-link" href="#">Experiments</a>
                </div>
                <div class="ga-sidebar-group open">
                    <button class="ga-sidebar-group-title" type="button">
                        <span>Assets</span>
                        <span class="material-symbols-outlined">expand_less</span>
                    </button>
                    <a class="ga-sidebar-link" :class="{ active: pageMode === 'adassets' }" :href="adAssetsHref">Assets</a>
                </div>
                <a class="ga-sidebar-link" href="#">Audiences, keywords, and content</a>
                <a class="ga-sidebar-link" href="#">Change history</a>
            </nav>

            <main class="ga-main">
                <section class="ga-context-bar" :class="{ hidden: isContextBarHidden }">
                    <div class="ga-selectors">
                        <div class="ga-selector active" @click.stop="toggleDropdown('view')">
                            <small>View (2 filters)</small>
                            <strong><span class="material-symbols-outlined">home</span> All campaigns</strong>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'view'" class="ga-dropdown">
                                <a href="/aw/campaigns">All campaigns</a>
                            </div>
                        </div>
                        <div class="ga-selector" :class="{ active: selectedCampaign }" @click.stop="toggleDropdown('campaign')">
                            <small>{{ campaignSelectorLabel }}</small>
                            <strong>{{ selectedCampaign ? selectedCampaign.campaign : 'Select a campaign' }}</strong>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'campaign'" class="ga-dropdown wide">
                                <a v-for="campaign in campaignRows" :key="campaign.id" :href="campaignHref(campaign.id)">
                                    {{ campaign.campaign }}
                                </a>
                            </div>
                        </div>
                        <div v-if="pageMode !== 'campaigns'" class="ga-selector" :class="{ active: pageMode === 'adassets' }"
                            @click.stop="toggleDropdown('adgroup')">
                            <small>Ad groups (1)</small>
                            <strong>{{ pageMode === 'adassets' ? adGroup.adGroup : 'Select an ad group' }}</strong>
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                            <div v-if="dropdown === 'adgroup'" class="ga-dropdown">
                                <a :href="adAssetsHref">{{ adGroup.adGroup }}</a>
                            </div>
                        </div>
                    </div>
                    <div v-if="pageMode !== 'campaigns'" class="ga-state-line">
                        <span :class="['ga-dot', selectedCampaignStatusClass]"></span>
                        <span>{{ selectedCampaignStateLabel }}</span>
                        <span>Status: <a href="#" :class="{ danger: isSelectedCampaignProblem }">{{ selectedCampaignStatusText }}</a></span>
                        <span>Account: {{ selectedCampaign ? selectedCampaign.account : '' }}</span>
                        <span>Type: {{ selectedCampaign ? selectedCampaign.campaignType : 'App' }}</span>
                        <span v-if="pageMode === 'adgroups'">Budget: <a href="#">{{ selectedCampaign ? selectedCampaign.budget : '' }}</a></span>
                        <span v-if="pageMode === 'adassets'">Target CPA: <a href="#">{{ adGroup.targetCpa }}</a></span>
                        <a class="ga-settings-link" href="#">
                            <span class="material-symbols-outlined">settings</span>
                            {{ pageMode === 'adassets' ? 'Ad group settings' : 'Campaign settings' }}
                        </a>
                    </div>
                </section>

                <section class="ga-page-head">
                    <div>
                        <h1>{{ pageTitle }}</h1>
                        <div v-if="pageMode !== 'adgroups'" class="ga-tabs">
                            <button class="active" type="button">{{ pageMode === 'adassets' ? 'Assets' : 'Campaigns' }}</button>
                            <button type="button">{{ pageMode === 'adassets' ? 'Combinations' : 'Settings' }}</button>
                        </div>
                    </div>
                    <div class="ga-date-row">
                        <span>Custom</span>
                        <button class="ga-date-button" type="button">
                            {{ data.dateRange.label }}
                            <span class="material-symbols-outlined">arrow_drop_down</span>
                        </button>
                        <span class="material-symbols-outlined">chevron_left</span>
                        <span class="material-symbols-outlined">chevron_right</span>
                        <a href="#">Show last 30 days</a>
                    </div>
                </section>

                <div v-if="pageMode !== 'adassets'" class="ga-info-banner">
                    <span class="material-symbols-outlined">info</span>
                    <span>You are viewing data between {{ data.dateRange.start }} and {{ data.dateRange.end }}</span>
                    <a href="#">Change date range</a>
                    <a href="#">Dismiss</a>
                </div>

                <section v-if="pageMode !== 'adassets'" class="ga-metrics">
                    <div v-for="(metric, index) in metricCards" :key="metric.label" class="ga-metric-card"
                        :class="{ primary: index === 0 }">
                        <span>{{ metric.label }}</span>
                        <strong>{{ metric.value }}</strong>
                        <small>{{ metric.delta }}</small>
                    </div>
                    <div class="ga-metric-actions">
                        <button v-for="action in metricActions" :key="action.label" type="button">
                            <span class="material-symbols-outlined">{{ action.icon }}</span>
                            <small>{{ action.label }}</small>
                            <b v-if="action.badge">{{ action.badge }}</b>
                        </button>
                    </div>
                </section>

                <section v-if="pageMode === 'adassets'" class="ga-asset-strength">
                    <div class="ga-strength-message">
                        <span class="material-symbols-outlined">info</span>
                        <span>Add videos to make more compelling ads.</span>
                    </div>
                    <div class="ga-strength-score">
                        <span class="ga-ring"></span>
                        <div><strong>Ad strength</strong><span>Poor</span></div>
                    </div>
                    <div class="ga-strength-counts">
                        <span><b></b>Headlines {{ data.assetSummary.headlines }}</span>
                        <span><b></b>Descriptions {{ data.assetSummary.descriptions }}</span>
                        <span><b></b>Images {{ data.assetSummary.images }}</span>
                        <span><b></b>Videos {{ data.assetSummary.videos }}</span>
                    </div>
                    <span class="material-symbols-outlined">expand_more</span>
                </section>

                <section class="ga-chart-area">
                    <svg viewBox="0 0 1000 180" preserveAspectRatio="none" aria-label="Performance chart">
                        <rect v-for="x in [35, 300, 565, 830]" :key="x" :x="x" y="18" width="38" height="136" class="ga-chart-band"></rect>
                        <line x1="20" y1="28" x2="980" y2="28"></line>
                        <line x1="20" y1="90" x2="980" y2="90"></line>
                        <line x1="20" y1="154" x2="980" y2="154"></line>
                        <polyline points="20,154 980,154" class="ga-chart-line"></polyline>
                    </svg>
                    <span class="ga-chart-start">Apr 11, 2026</span>
                    <span class="ga-chart-end">May 8, 2026</span>
                </section>

                <section class="ga-table-panel">
                    <button class="ga-floating-add" type="button" :aria-label="pageMode === 'adassets' ? 'Edit' : 'Create'">
                        <span class="material-symbols-outlined">{{ pageMode === 'adassets' ? 'edit' : 'add' }}</span>
                    </button>
                    <div class="ga-table-toolbar">
                        <div class="ga-toolbar-left">
                            <span class="material-symbols-outlined">filter_alt</span>
                            <button v-if="pageMode === 'adassets'" class="ga-filter-badge" type="button">Asset status: All enabled</button>
                            <span>Add filter</span>
                        </div>
                        <div class="ga-toolbar-actions">
                            <button v-for="tool in tableTools" :key="tool.label" type="button">
                                <span class="material-symbols-outlined">{{ tool.icon }}</span>
                                <small>{{ tool.label }}</small>
                            </button>
                            <button type="button">
                                <span class="material-symbols-outlined">keyboard_arrow_up</span>
                            </button>
                        </div>
                    </div>

                    <div v-if="pageMode === 'adassets'" class="ga-policy-alert">
                        Ad violates policy and can't run:
                        <a href="#">Destination not working</a>
                    </div>

                    <div class="ga-table-scroll">
                        <table v-if="pageMode === 'campaigns'" class="ga-data-table campaigns">
                            <thead>
                                <tr>
                                    <th class="select-col"><span class="ga-checkbox"></span></th>
                                    <th class="state-col"><span class="ga-status-dot"></span></th>
                                    <th class="name-col">Campaign <span class="material-symbols-outlined">arrow_upward</span></th>
                                    <th>Budget</th>
                                    <th>Status</th>
                                    <th>Optimization score</th>
                                    <th>Account</th>
                                    <th>Campaign type</th>
                                    <th>Cost / Install</th>
                                    <th>Cost / In-app action</th>
                                    <th>View-through conv.</th>
                                    <th>Installs</th>
                                    <th>In-app actions</th>
                                    <th>Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="draft-row">
                                    <td></td>
                                    <td><span class="material-symbols-outlined">expand_more</span></td>
                                    <td><span class="material-symbols-outlined">folder</span> Drafts in progress: 0</td>
                                    <td colspan="11"></td>
                                </tr>
                                <tr v-for="campaign in campaignRows" :key="campaign.id">
                                    <td><span class="ga-checkbox"></span></td>
                                    <td><span :class="['ga-status-dot', statusDotClass(campaign.campaignStatus)]"></span></td>
                                    <td class="name-col">
                                        <span class="material-symbols-outlined ga-campaign-type">download_for_offline</span>
                                        <a :href="campaignHref(campaign.id)">{{ campaign.campaign }}</a>
                                    </td>
                                    <td>{{ campaign.budget }}</td>
                                    <td><span class="ga-dashed">{{ campaign.status }}</span></td>
                                    <td>{{ dash(campaign.optimizationScore) }}</td>
                                    <td><a href="#">{{ campaign.account }}</a></td>
                                    <td>{{ campaign.campaignType }}</td>
                                    <td>{{ moneyOrDash(campaign.costPerInstall) }}</td>
                                    <td>{{ moneyOrDash(campaign.costPerInAppAction) }}</td>
                                    <td>{{ numberOrZero(campaign.viewThroughConv) }}</td>
                                    <td>{{ numberOrZero(campaign.installs) }}</td>
                                    <td>{{ numberOrZero(campaign.inAppActions) }}</td>
                                    <td>{{ money(campaign.cost) }}</td>
                                </tr>
                                <tr class="total-row">
                                    <td colspan="3">Total: All but removed campaigns in your current view</td>
                                    <td></td>
                                    <td></td>
                                    <td>-</td>
                                    <td></td>
                                    <td></td>
                                    <td>-</td>
                                    <td>-</td>
                                    <td>{{ numberOrZero(totals.viewThroughConv) }}</td>
                                    <td>{{ numberOrZero(totals.installs) }}</td>
                                    <td>{{ numberOrZero(totals.inAppActions) }}</td>
                                    <td>{{ money(totals.cost) }}</td>
                                </tr>
                            </tbody>
                        </table>

                        <table v-if="pageMode === 'adgroups'" class="ga-data-table adgroups">
                            <thead>
                                <tr>
                                    <th class="select-col"><span class="ga-checkbox"></span></th>
                                    <th class="state-col"><span class="ga-status-dot"></span></th>
                                    <th class="name-col">Ad group <span class="material-symbols-outlined">arrow_downward</span></th>
                                    <th>Status</th>
                                    <th>Target CPA</th>
                                    <th>Conversions</th>
                                    <th>Cost / conv.</th>
                                    <th>Cost / Install</th>
                                    <th>Cost / In-app action</th>
                                    <th>View-through conv.</th>
                                    <th>Brand Inclusions</th>
                                    <th>Locations of interest</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><span class="ga-checkbox"></span></td>
                                    <td><span class="ga-status-dot enabled"></span></td>
                                    <td class="name-col"><a :href="adAssetsHref">{{ adGroup.adGroup }}</a></td>
                                    <td><span class="danger">Not eligible</span><br><span class="ga-dashed">Ad group is disapproved</span><br><span class="ga-dashed">Campaign is paused</span></td>
                                    <td>{{ adGroup.targetCpa }}</td>
                                    <td>{{ numberOrZero(selectedConversions) }}</td>
                                    <td>{{ moneyOrDash(selectedCostPerConv) }}</td>
                                    <td>{{ moneyOrDash(selectedCostPerInstall) }}</td>
                                    <td>{{ moneyOrDash(selectedCostPerInAppAction) }}</td>
                                    <td>{{ numberOrZero(selectedCampaign ? selectedCampaign.viewThroughConv : 0) }}</td>
                                    <td>-</td>
                                    <td>-</td>
                                </tr>
                                <tr class="total-row">
                                    <td colspan="5">Total: All but removed ad groups in your campaign</td>
                                    <td>{{ numberOrZero(selectedConversions) }}</td>
                                    <td>{{ money(selectedCostPerConv) }}</td>
                                    <td>-</td>
                                    <td>-</td>
                                    <td>{{ numberOrZero(selectedCampaign ? selectedCampaign.viewThroughConv : 0) }}</td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr class="total-row">
                                    <td colspan="5">Total: Campaign</td>
                                    <td>{{ numberOrZero(selectedConversions) }}</td>
                                    <td>{{ money(selectedCostPerConv) }}</td>
                                    <td>-</td>
                                    <td>-</td>
                                    <td>{{ numberOrZero(selectedCampaign ? selectedCampaign.viewThroughConv : 0) }}</td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>

                        <table v-if="pageMode === 'adassets'" class="ga-data-table assets">
                            <thead>
                                <tr>
                                    <th class="state-col"><span class="ga-status-dot"></span></th>
                                    <th class="name-col">Asset</th>
                                    <th>Status</th>
                                    <th>Asset type <span class="material-symbols-outlined">arrow_upward</span></th>
                                    <th>Performance</th>
                                    <th>Clicks</th>
                                    <th>CTR</th>
                                    <th>Impr.</th>
                                    <th>Cost <span class="material-symbols-outlined">arrow_downward</span></th>
                                    <th>Installs</th>
                                    <th>Cost / Install</th>
                                    <th>In-app actions</th>
                                    <th>Cost / In-app action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr v-for="asset in assetRows" :key="asset.id">
                                    <td><span class="ga-status-dot enabled"></span></td>
                                    <td class="asset-cell">
                                        <button v-if="asset.assetType === 'Image'" type="button" class="asset-thumb"
                                            @click="openImagePreview(asset)">
                                            <img :src="asset.image" :alt="asset.asset">
                                        </button>
                                        <div>
                                            <span>{{ asset.asset }}</span>
                                            <button type="button" class="link-button" @click="openUnavailablePreview">View ad previews</button>
                                        </div>
                                    </td>
                                    <td>{{ asset.status }}</td>
                                    <td>{{ asset.assetType }}</td>
                                    <td><span class="ga-dashed">{{ asset.performance }}</span></td>
                                    <td>{{ numberOrZero(asset.clicks) }}</td>
                                    <td>{{ asset.clicks ? percent(asset.ctr) : '-' }}</td>
                                    <td>{{ numberOrZero(asset.impressions) }}</td>
                                    <td>{{ money(asset.cost) }}</td>
                                    <td>{{ numberOrZero(asset.installs) }}</td>
                                    <td>{{ moneyOrDash(asset.costPerInstall) }}</td>
                                    <td>{{ numberOrZero(asset.inAppActions) }}</td>
                                    <td>{{ moneyOrDash(asset.costPerInAppAction) }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="ga-pagination">
                        <span>Show rows:</span>
                        <button type="button">{{ pageMode === 'campaigns' ? 100 : 50 }} <span class="material-symbols-outlined">arrow_drop_down</span></button>
                        <span>{{ paginationText }}</span>
                        <span class="material-symbols-outlined muted">first_page</span>
                        <span class="material-symbols-outlined muted">chevron_left</span>
                        <span class="material-symbols-outlined muted">chevron_right</span>
                        <span class="material-symbols-outlined muted">last_page</span>
                    </div>
                </section>

                <footer class="ga-footer">
                    <p><a href="#">Reporting is not real-time.</a> Time zone for all dates and times: (GMT+08:00) China Standard Time. <a href="#">Learn more</a></p>
                    <p>Some inventory may be provided through third party intermediaries.</p>
                    <p>You'll see Media Rating Council (MRC) accreditation noted in the column header's hover text for accredited metrics.</p>
                    <p>&copy; Google, 2026.</p>
                </footer>
            </main>
        </div>

        <div v-if="previewModal" class="ga-modal-backdrop" @click.self="closePreview">
            <section v-if="previewModal.type === 'unavailable'" class="ga-preview-modal unavailable">
                <h2>Ad previews</h2>
                <p>Ad previews aren't available for this asset</p>
                <button type="button" @click="closePreview">Close</button>
            </section>
            <section v-if="previewModal.type === 'image'" class="ga-preview-modal image-preview">
                <div class="ga-preview-stage">
                    <button class="ga-preview-close" type="button" @click="closePreview">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                    <h2>{{ previewModal.asset.source }}</h2>
                    <img :src="previewModal.asset.image" :alt="previewModal.asset.asset">
                </div>
                <aside class="ga-preview-details">
                    <h2>About this asset</h2>
                    <h3>{{ previewModal.asset.source }}</h3>
                    <dl>
                        <dt>Asset ID</dt>
                        <dd>{{ previewModal.asset.assetId }}</dd>
                        <dt>Type</dt>
                        <dd>{{ previewModal.asset.assetType }}</dd>
                        <dt>Dimensions</dt>
                        <dd>{{ previewModal.asset.dimensions }}</dd>
                        <dt>Orientation</dt>
                        <dd>{{ previewModal.asset.orientation }}</dd>
                        <dt>Aspect ratio</dt>
                        <dd>{{ previewModal.asset.aspectRatio }}</dd>
                        <dt>Source</dt>
                        <dd>Advertiser</dd>
                    </dl>
                </aside>
            </section>
        </div>
    </div>

    <script>
        window.GOOGLE_ADS_PAGE = <%- JSON.stringify(page) %>;
    </script>
    <script src="/js/vue.global.js"></script>
    <script src="/google_ads.js"></script>
</body>

</html>
